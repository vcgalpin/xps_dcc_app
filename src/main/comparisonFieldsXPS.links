# module for startXPS.links
#
# provides list of DCC fields to select information for comparison

# XPS application specific
open import DatabaseXPS;
open import TypesXPS;
open import XmlXPS;
open import ComparisonInfoXPS;

#================ TYPES =============================

typename Status = [| Disabled 
                   | Selected 
                   | Unselected |];

typename Option = (opt_label: String, 
                   status: Status);

typename DataItem = (doc_id: Int,
                     cal_label: String, 
                     value: String,
                     duplicate: Bool); # if dde is found more than once

typename DccField = (path: String,
                     fld_label: String, 
                     descr: String, 
                     ddeString: String,
                     options: [Option],
                     dataList: [DataItem] );

#================ VARIABLES =============================

#=== different analysis options for a DCC field

var no_options = [(opt_label = "List", status = Disabled),
                    (opt_label = "Stats", status = Disabled),
                    (opt_label = "Stats_PE", status = Disabled)];

var list_options = [(opt_label = "List", status = Unselected),
                    (opt_label = "Stats", status = Disabled),
                    (opt_label = "Stats_PE", status = Disabled)];

var liststats_options = [(opt_label = "List", status = Unselected),
                    (opt_label = "Stats", status = Unselected),
                    (opt_label = "Stats_PE", status = Disabled)];

#var list_selected_options = [(opt_label = "List", status = Selected),
#                    (opt_label = "Stats", status = Disabled),
#                    (opt_label = "Stats_PE", status = Disabled)];

#var stats_statsEV_selected_options = [(opt_label = "List", status = Disabled),
#                    (opt_label = "Stats", status = Selected),
#                    (opt_label = "Stats_PE", status = Selected)];

#var stats_options = [(opt_label = "List", status = Disabled),
#                    (opt_label = "Stats", status = Unselected),
#                    (opt_label = "Stats_PE", status = Unselected)];


#============ FUNCTIONS ==================================


fun listFieldsMR () {
  # >>>>>>>>
  [(path = "dcc:measurementResults/dcc:measurementResult/dcc:name/...", descr = "...", 
     fld_label = "dcc:measurementResults/dcc:measurementResult/dcc:name/...",
     options = no_options, dataList = [],
     ddeString = ""),
   (path = "dcc:measurementResults/dcc:measurementResult/dcc:usedMethods/...", descr = "...", 
     fld_label = "dcc:measurementResults/dcc:measurementResult/dcc:usedMethods/...",
     options = no_options, dataList = [],
     ddeString = ""),
   (path = "dcc:measurementResults/dcc:measurementResult/dcc:influenceConditions/...", descr = "...",
     fld_label = "dcc:measurementResults/dcc:measurementResult/dcc:influenceConditions/...", 
     options = no_options, dataList = [],
     ddeString = ""),
   (path = "dcc:measurementResults/dcc:measurementResult/dcc:results/...", descr = "...", 
     fld_label = "dcc:measurementResults/dcc:measurementResult/dcc:results/...",
     options = no_options, dataList = [],
     ddeString = ""),

   (path = "dcc:measurementResults/dcc:measurementResult/dcc:results/dcc:result/dcc:data/dcc:quantity/si:real/si:expandedUnc/si:uncertainty", descr = "Uncertainty",
     fld_label = "dcc:measurementResults/dcc:measurementResult/dcc:results/dcc:result/.../si:expandedUnc/si:uncertainty", 
     options = liststats_options, dataList = [],
     ddeString = "+001.+002.+001.+004.+007.+003.+001.+002.+003.+001.+001"),
   (path = "dcc:measurementResults/dcc:measurementResult/dcc:results/dcc:result/dcc:data/dcc:quantity/si:real/si:expandedUnc/si:coverageFactor", descr = "Coverage Factor", 
     fld_label = "dcc:measurementResults/dcc:measurementResult/dcc:results/dcc:result/.../si:expandedUnc/si:coverageFactor",
     options = liststats_options, dataList = [],
     ddeString = "+001.+002.+001.+004.+007.+003.+001.+002.+003.+002.+001"),
   (path = "dcc:measurementResults/dcc:measurementResult/dcc:results/dcc:result/dcc:data/dcc:quantity/si:real/si:expandedUnc/si:coverageProbability", descr = "Probability", 
     fld_label = "dcc:measurementResults/dcc:measurementResult/dcc:results/dcc:result/.../si:expandedUnc/si:coverageProbability", dataList = [],
     options = liststats_options,
     ddeString = "+001.+002.+001.+004.+007.+003.+001.+002.+003.+003.+001"),

   (path = "dcc:measurementResult/dcc:measurementMetaData/...", descr = "...", 
     fld_label = "dcc:measurementResult/dcc:measurementMetaData/...",
     options = no_options, dataList = [],
     ddeString = "")]
}


